# ==========================================
# MySQL 数据库连接配置
# 使用方法：复制此文件为 db.properties 并修改参数
#   cp src/db.properties.example src/db.properties
# ==========================================
db.url=jdbc:mysql://localhost:3306/atm?useSSL=false&characterEncoding=utf8&serverTimezone=Asia/Shanghai
db.username=你的MySQL用户名
db.password=你的MySQL密码
db.driver=com.mysql.cj.jdbc.Driver
